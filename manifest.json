{
  "manifest_version": 3,
  "name": "SardarJi Appointment Scheduler",
  "version": "1.2.4",
  "description": "Smart visa appointment slot monitor and scheduler",
  "key": "",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "offscreen",
    "tabs",
    "activeTab",
    "browsingData",
    "cookies",
    "sidePanel",
    "nativeMessaging",
    "downloads"
  ],
  "host_permissions": [
    "https://ais.usvisa-info.com/*",
    "https://api.telegram.org/*",
    "https://raw.githubusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://ais.usvisa-info.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
